<div class="mb-10">
    <h2 class="text-4xl font-black tracking-tight font-serif-heading text-white">Vi phạm & Thanh toán</h2>
    <p class="text-zinc-400 mt-1 font-medium italic">Quản lý các khoản phạt cá nhân của bạn.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <!-- Unpaid Fines List -->
    <div class="lg:col-span-2 space-y-6">
        <div class="flex items-center justify-between mb-2">
            <h3 class="text-xl font-black text-rose-500 uppercase tracking-widest"><i class="fa-solid fa-triangle-exclamation mr-3"></i>Khoản phạt cần đóng</h3>
            <span class="text-xs font-black text-rose-400 bg-rose-500/10 px-3 py-1 rounded-lg border border-rose-500/20"><%= myFines.length %> LỖI</span>
        </div>

        <% if (myFines && myFines.length > 0) { %>
            <% myFines.forEach(fine => { %>
                <div class="glass-card p-8 border-rose-500/20 bg-zinc-900/40 group hover:border-rose-500/50 transition-all">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <span class="text-[10px] font-black text-rose-500 bg-rose-500/10 px-2 py-1 rounded uppercase tracking-widest mb-3 inline-block">Chưa thanh toán</span>
                            <h4 class="text-2xl font-black text-white mb-1"><%= fine.reason %></h4>
                            <p class="text-xs text-zinc-500">Ghi nhận lúc: <%= moment(fine.createdAt).format('HH:mm - DD/MM/YYYY') %></p>
                        </div>
                        <div class="text-right">
                            <p class="text-3xl font-black text-rose-500 font-serif-heading"><%= fine.amount.toLocaleString('vi-VN') %>đ</p>
                            <p class="text-[10px] text-zinc-500 font-bold italic mt-1">Gốc: <%= fine.originalAmount.toLocaleString('vi-VN') %>đ</p>
                        </div>
                    </div>

                    <div class="p-4 bg-amber-500/5 border border-amber-500/20 rounded-2xl mb-6 flex items-center gap-4">
                        <div class="w-10 h-10 bg-amber-500/10 rounded-xl flex items-center justify-center text-amber-500">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>
                        <div>
                            <p class="text-[10px] text-amber-500 font-black uppercase tracking-widest mb-0.5">Cảnh báo lãi suất</p>
                            <p class="text-xs text-zinc-400">Tiền phạt đã tăng thêm do nộp muộn. Mỗi ngày tiếp theo sẽ tăng thêm <strong class="text-amber-400">2.5%</strong>.</p>
                        </div>
                    </div>

                    <a href="/room/pay-fine/<%= fine._id %>" 
                        class="w-full py-4 bg-rose-500 text-white font-black rounded-xl hover:bg-rose-400 transition-all flex items-center justify-center gap-3 shadow-xl shadow-rose-500/20 uppercase tracking-widest text-sm">
                        <i class="fa-solid fa-credit-card"></i> THANH TOÁN TỰ ĐỘNG QUA PAYOS
                    </a>
                </div>
            <% }) %>
        <% } else { %>
            <div class="glass-card p-16 text-center opacity-30 border-emerald-500/20">
                <i class="fa-solid fa-circle-check text-7xl text-emerald-500 mb-6"></i>
                <p class="text-lg font-black uppercase tracking-widest">Tuyệt vời! Bạn không có vi phạm nào.</p>
            </div>
        <% } %>
    </div>

    <!-- History & Sidebar -->
    <div class="space-y-10">
        <!-- History -->
        <div class="glass-card p-8">
            <h3 class="text-lg font-black text-zinc-400 uppercase tracking-widest mb-6"><i class="fa-solid fa-clock-rotate-left mr-3"></i>Lịch sử đóng phạt</h3>
            <div class="space-y-6">
                <% if (paidHistory && paidHistory.length > 0) { %>
                    <% paidHistory.forEach(fine => { %>
                        <div class="pb-6 border-b border-white/5 last:border-0 last:pb-0">
                            <div class="flex justify-between items-start mb-2">
                                <h5 class="text-sm font-bold text-zinc-200"><%= fine.reason %></h5>
                                <span class="text-xs font-black text-emerald-500"><%= fine.amount.toLocaleString('vi-VN') %>đ</span>
                            </div>
                            <div class="flex justify-between items-center text-[10px] text-zinc-500">
                                <span>Thanh toán: <%= moment(fine.paymentDate).format('DD/MM/YYYY') %></span>
                                <span class="text-emerald-500/50 uppercase">Thành công</span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-xs text-zinc-600 italic">Chưa có lịch sử thanh toán.</p>
                <% } %>
            </div>
        </div>

        <!-- Info Box -->
        <div class="glass-card p-8 bg-amber-500/5 border-amber-500/20">
            <h4 class="text-amber-500 font-black uppercase tracking-widest text-xs mb-4">Lưu ý về quy định</h4>
            <ul class="space-y-4">
                <li class="flex gap-3 text-xs text-zinc-400 leading-relaxed">
                    <i class="fa-solid fa-check text-amber-500 mt-0.5"></i>
                    <span>Tất cả tiền phạt sẽ được chuyển trực tiếp vào <strong>Quỹ Phòng</strong> sau khi thanh toán thành công.</span>
                </li>
                <li class="flex gap-3 text-xs text-zinc-400 leading-relaxed">
                    <i class="fa-solid fa-check text-amber-500 mt-0.5"></i>
                    <span>Hệ thống sử dụng PayOS để tự động ghi nhận thanh toán, vui lòng không tắt trình duyệt khi đang xử lý.</span>
                </li>
            </ul>
        </div>
    </div>
</div>
