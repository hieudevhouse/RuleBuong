<!-- Left Form Section -->
<div class="w-full lg:w-7/12 flex flex-col justify-center p-10 md:p-20 bg-obsidian-500/50">
    <div class="max-w-xl w-full mx-auto">
        <div class="mb-10">
            <h2 class="text-4xl font-black text-white font-serif-heading mb-3">Tạo tài khoản mới</h2>
            <p class="text-zinc-500 font-medium">Bắt đầu hành trình quản lý cuộc sống chung chuyên nghiệp.</p>
        </div>

        <% if (typeof error !== 'undefined') { %>
            <div class="mb-8 p-5 bg-rose-500/5 border border-rose-500/20 rounded-2xl flex items-center gap-4 text-rose-500 animate-shake">
                <div class="w-10 h-10 bg-rose-500 text-white rounded-xl flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-circle-exclamation"></i>
                </div>
                <p class="text-xs font-black uppercase tracking-widest"><%= error %></p>
            </div>
        <% } %>

        <form action="/auth/register" method="POST" enctype="multipart/form-data" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-3">
                    <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Họ và tên</label>
                    <div class="relative group">
                        <i class="fa-regular fa-user absolute left-5 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-gold-500 transition-colors"></i>
                        <input type="text" name="fullName" required placeholder="Nguyễn Văn A"
                            class="w-full bg-white/[0.03] border border-white/10 rounded-2xl pl-14 pr-6 py-3.5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
                    </div>
                </div>

                <div class="space-y-3">
                    <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Địa chỉ Email</label>
                    <div class="relative group">
                        <i class="fa-regular fa-envelope absolute left-5 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-gold-500 transition-colors"></i>
                        <input type="email" name="email" required placeholder="name@company.com"
                            class="w-full bg-white/[0.03] border border-white/10 rounded-2xl pl-14 pr-6 py-3.5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-3">
                    <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Mật khẩu</label>
                    <div class="relative group">
                        <i class="fa-solid fa-lock absolute left-5 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-gold-500 transition-colors"></i>
                        <input type="password" name="password" required placeholder="••••••••"
                            class="w-full bg-white/[0.03] border border-white/10 rounded-2xl pl-14 pr-6 py-3.5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
                    </div>
                </div>

                <div class="space-y-3">
                    <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Xác nhận</label>
                    <div class="relative group">
                        <i class="fa-solid fa-shield-check absolute left-5 top-1/2 -translate-y-1/2 text-zinc-600 group-focus-within:text-gold-500 transition-colors"></i>
                        <input type="password" name="confirmPassword" required placeholder="••••••••"
                            class="w-full bg-white/[0.03] border border-white/10 rounded-2xl pl-14 pr-6 py-3.5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
                    </div>
                </div>
            </div>

            <div class="space-y-3">
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Mã QR Thanh toán (Tùy chọn)</label>
                <div class="relative group">
                    <div class="w-full bg-white/[0.02] border-2 border-dashed border-white/10 rounded-3xl p-8 flex flex-col items-center justify-center group-hover:border-gold-500/30 group-hover:bg-gold-500/5 transition-all cursor-pointer" onclick="document.getElementById('qrCode').click()">
                        <div id="qrIconArea" class="w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center text-zinc-500 mb-4 transition-all group-hover:bg-gold-500 group-hover:text-obsidian-500 group-hover:shadow-[0_0_30px_rgba(201,169,110,0.3)]">
                            <i class="fa-solid fa-qrcode text-2xl"></i>
                        </div>
                        <p id="qrText" class="text-xs font-black text-zinc-500 uppercase tracking-widest">Tải lên ảnh QR Ngân hàng</p>
                        <img id="qrPreview" class="mt-4 w-32 h-32 object-contain hidden border-4 border-white/10 rounded-2xl">
                    </div>
                    <input type="file" id="qrCode" name="qrCode" accept="image/*" class="hidden" onchange="previewQR(this)">
                </div>
            </div>

            <div class="pt-4">
                <button type="submit" class="btn-primary-glow w-full py-5 rounded-2xl text-base font-black uppercase tracking-widest text-obsidian-500">
                    Tạo tài khoản thành viên
                </button>
            </div>
        </form>

        <div class="mt-10 text-center">
            <p class="text-zinc-500 text-sm font-medium">
                Đã có tài khoản? 
                <a href="/auth/login" class="text-gold-500 font-black uppercase tracking-widest ml-2 hover:text-gold-400 transition-colors">Đăng nhập</a>
            </p>
        </div>
    </div>
</div>

<!-- Right Banner -->
<div class="hidden lg:flex lg:w-5/12 bg-obsidian-600 relative overflow-hidden flex-col justify-between p-16 border-l border-gold-500/10">
    <div class="relative z-10">
        <div class="w-16 h-16 bg-gold-500 rounded-2xl flex items-center justify-center text-obsidian-500 text-3xl font-black shadow-[0_0_40px_rgba(201,169,110,0.3)] mb-10">
            <i class="fa-solid fa-shield-heart"></i>
        </div>
        <h1 class="text-5xl font-black font-serif-heading text-white leading-tight mb-6">
            Minh bạch<br>
            <span class="text-gradient-gold italic">trong từng giao dịch.</span>
        </h1>
        <div class="space-y-6 max-w-sm">
            <div class="flex gap-4">
                <div class="w-10 h-10 bg-gold-500/10 border border-gold-500/20 rounded-xl flex items-center justify-center text-gold-500 shrink-0">
                    <i class="fa-solid fa-receipt"></i>
                </div>
                <div>
                    <h4 class="text-white font-black text-sm uppercase tracking-widest mb-1">Quỹ phòng tự động</h4>
                    <p class="text-zinc-500 text-xs font-medium">Theo dõi đóng quỹ và chi tiêu chung một cách minh bạch.</p>
                </div>
            </div>
            <div class="flex gap-4">
                <div class="w-10 h-10 bg-gold-500/10 border border-gold-500/20 rounded-xl flex items-center justify-center text-gold-500 shrink-0">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <div>
                    <h4 class="text-white font-black text-sm uppercase tracking-widest mb-1">Phạt vi phạm 2.5%</h4>
                    <p class="text-zinc-500 text-xs font-medium">Hệ thống tính lãi phạt tự động, đảm bảo kỷ luật nội quy.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="relative z-10">
        <div class="p-6 rounded-3xl bg-white/[0.03] border border-white/5 backdrop-blur-xl">
            <p class="text-sm text-gold-500/80 font-serif-heading italic leading-relaxed">
                "Pencake không chỉ là công cụ quản lý, nó là cầu nối cho một cộng đồng sống chung văn minh."
            </p>
        </div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute bottom-[-10%] right-[-10%] w-64 h-64 bg-gold-500/5 blur-[80px] rounded-full"></div>
</div>

<script>
    function previewQR(input) {
        const preview = document.getElementById('qrPreview');
        const text = document.getElementById('qrText');
        const iconArea = document.getElementById('qrIconArea');
        
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                text.innerText = 'Đã chọn: ' + input.files[0].name;
                text.classList.add('text-gold-500');
                iconArea.classList.add('bg-gold-500', 'text-obsidian-500');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>

<style>
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }
    .animate-shake {
        animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }
</style>