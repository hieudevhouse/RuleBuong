<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
    <div>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight font-serif-heading text-gradient-gold">Quản lý phòng trọ</h2>
        <div class="flex items-center gap-3 mt-2">
            <span class="w-8 h-px bg-gold-500/50"></span>
            <p class="text-zinc-400 font-medium italic">Buồng Vui Vẻ • <span class="text-gold-500 font-black tracking-[0.2em] uppercase text-[10px]">Hệ thống Pencake Premium</span></p>
        </div>
    </div>
    <div class="flex flex-wrap gap-4 w-full md:w-auto">
        <a href="#fund-history" class="flex-1 md:flex-none bg-obsidian-300 hover:bg-obsidian-200 px-6 py-4 rounded-2xl text-[11px] font-black transition-all text-white border border-white/5 uppercase tracking-widest shadow-lg active:scale-95 flex items-center justify-center">
            <i class="fa-solid fa-file-invoice-dollar mr-2 text-gold-500"></i> Lịch sử thu chi
        </a>
        <button onclick="document.getElementById('fineModal').classList.remove('hidden')" class="flex-1 md:flex-none bg-rose-500/10 hover:bg-rose-500 hover:text-white px-6 py-4 rounded-2xl text-[10px] font-black transition-all text-rose-500 border border-rose-500/20 uppercase tracking-widest shadow-lg active:scale-95 flex items-center justify-center">
            <i class="fa-solid fa-plus-circle mr-2"></i> Vi phạm
        </button>
        <button onclick="document.getElementById('fundUsageModal').classList.remove('hidden')" class="flex-1 md:flex-none bg-white/5 hover:bg-white/10 px-6 py-4 rounded-2xl text-[10px] font-black transition-all text-white border border-white/5 uppercase tracking-widest shadow-lg active:scale-95 flex items-center justify-center">
            <i class="fa-solid fa-receipt mr-2 text-gold-500"></i> Sử dụng quỹ
        </button>
        <a href="/room/purchases" class="flex-1 md:flex-none btn-primary-glow px-8 py-4 rounded-2xl text-[10px] font-black transition-all text-obsidian-500 uppercase tracking-widest shadow-xl active:scale-95 flex items-center justify-center">
            <i class="fa-solid fa-shopping-cart mr-2"></i> Mua đồ chung
        </a>
    </div>
</div>

<!-- Rules CTA Section -->
<div class="glass-card p-8 md:p-12 mb-10 overflow-hidden relative group border-gold-500/10">
    <div class="absolute inset-0 bg-gradient-to-r from-gold-500/5 to-transparent opacity-50"></div>
    <div class="relative z-10 flex flex-col lg:flex-row items-center justify-between gap-8">
        <div class="flex flex-col md:flex-row items-center gap-8 text-center md:text-left">
            <div class="w-20 h-20 bg-gold-500/10 rounded-3xl flex items-center justify-center text-gold-500 text-4xl shadow-2xl shadow-gold-500/5 border border-gold-500/20">
                <i class="fa-solid fa-scroll"></i>
            </div>
            <div>
                <h3 class="text-3xl font-black font-serif-heading text-white">Hiến Pháp Buồng Vui Vẻ</h3>
                <p class="text-xs text-zinc-500 mt-2 uppercase tracking-[0.2em] font-black">10 Điều Kỷ Luật & Chế Tài Xử Phạt Nội Bộ</p>
                <div class="flex items-center gap-4 mt-4 justify-center md:justify-start">
                    <span class="px-3 py-1 bg-white/5 rounded-full text-[9px] font-black text-zinc-400 border border-white/5 uppercase">Cập nhật 2024</span>
                    <span class="px-3 py-1 bg-gold-500/10 rounded-full text-[9px] font-black text-gold-500 border border-gold-500/10 uppercase">Lãi suất 2.5% / ngày</span>
                </div>
            </div>
        </div>
        <a href="/room/rules" class="w-full lg:w-auto bg-white hover:bg-gold-100 text-obsidian-500 px-12 py-5 rounded-2xl text-[13px] font-black transition-all uppercase tracking-widest shadow-2xl shadow-white/5 active:scale-95 flex items-center justify-center gap-3 group">
            <span>Xem Chi Tiết Nội Quy</span>
            <i class="fa-solid fa-arrow-right-long text-lg group-hover:translate-x-1 transition-transform"></i>
        </a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
    <!-- Total Fund Card -->
    <div class="glass-card p-10 bg-gold-500/[0.02] border-gold-500/10 shadow-2xl shadow-gold-500/5 cursor-pointer hover:bg-gold-500/[0.05] transition-all group" onclick="document.getElementById('fundHistorySection').scrollIntoView({behavior: 'smooth'})">
        <div class="flex justify-between items-start mb-6">
            <h3 class="text-zinc-500 text-[11px] font-black uppercase tracking-[0.2em]">Tổng Quỹ Phòng</h3>
            <div class="w-8 h-8 bg-gold-500/10 rounded-lg flex items-center justify-center text-gold-500 text-xs">
                <i class="fa-solid fa-vault"></i>
            </div>
        </div>
        <p class="text-5xl font-black text-white font-serif-heading"><%= currentFund.toLocaleString('vi-VN') %><span class="text-lg font-sans text-gold-500 ml-2">VNĐ</span></p>
        <div class="mt-8 flex items-center gap-3">
            <div class="w-2 h-2 bg-gold-500 rounded-full animate-pulse shadow-[0_0_12px_#C9A96E]"></div>
            <span class="text-[10px] text-zinc-500 font-black uppercase tracking-widest">Dòng tiền minh bạch • Hoạt động</span>
        </div>
    </div>

    <!-- Today's Duty Card -->
    <div class="glass-card p-10 border-white/5 bg-obsidian-200">
        <div class="flex justify-between items-start mb-6">
            <h3 class="text-zinc-500 text-[11px] font-black uppercase tracking-[0.2em]">Trực Nhật Hôm Nay</h3>
            <div class="w-8 h-8 bg-blue-500/10 rounded-lg flex items-center justify-center text-blue-400 text-xs">
                <i class="fa-solid fa-calendar-check"></i>
            </div>
        </div>
        <% if (todayDuty) { %>
            <div class="flex items-center gap-5 mt-4">
                <div class="relative group">
                    <div class="absolute inset-0 bg-gold-500/20 rounded-2xl blur-md opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <% if (todayDuty.userId.avatar) { %>
                        <img src="<%= todayDuty.userId.avatar %>" class="relative w-16 h-16 rounded-2xl object-cover border-2 border-white/5 group-hover:border-gold-500/50 transition-all">
                    <% } else { %>
                        <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(todayDuty.userId.fullName) %>&background=C9A96E&color=09090B" class="relative w-16 h-16 rounded-2xl border-2 border-white/5 group-hover:border-gold-500/50 transition-all">
                    <% } %>
                    <div class="absolute -bottom-2 -right-2 w-7 h-7 bg-gold-500 rounded-full flex items-center justify-center text-obsidian-500 text-[10px] shadow-lg border-2 border-obsidian-200">
                        <i class="fa-solid fa-broom"></i>
                    </div>
                </div>
                <div>
                    <p class="text-xl font-black text-white leading-none"><%= todayDuty.userId.fullName %></p>
                    <p class="text-[10px] text-gold-500 font-black uppercase tracking-widest mt-2 bg-gold-500/10 px-2 py-0.5 rounded border border-gold-500/20 inline-block"><%= todayDuty.task %></p>
                </div>
            </div>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-4 opacity-20">
                <i class="fa-solid fa-mug-hot text-4xl text-zinc-500 mb-2"></i>
                <p class="text-[10px] font-black uppercase tracking-[0.2em]">Hôm nay nghỉ ngơi</p>
            </div>
        <% } %>
    </div>

    <!-- Unpaid Fines Card -->
    <div class="glass-card p-10 border-rose-500/20 bg-rose-500/[0.02] cursor-pointer hover:bg-rose-500/[0.05] transition-all group" onclick="document.getElementById('unpaidFinesModal').classList.remove('hidden')">
        <div class="flex justify-between items-start mb-6">
            <h3 class="text-zinc-500 text-[11px] font-black uppercase tracking-[0.2em]">Tổng Phạt Chưa Đóng</h3>
            <div class="w-8 h-8 bg-rose-500/10 rounded-lg flex items-center justify-center text-rose-500 text-xs">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
        </div>
        <p class="text-4xl font-black text-rose-500 font-serif-heading"><%= totalUnpaidFines.toLocaleString('vi-VN') %><span class="text-lg font-sans text-rose-500/40 ml-2">VNĐ</span></p>
        <div class="mt-8 flex items-center justify-between">
            <span class="text-[10px] text-rose-400 font-black uppercase tracking-widest">Yêu cầu thanh toán</span>
            <div class="flex -space-x-2">
                <% members.slice(0, 3).forEach(m => { %>
                    <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(m.fullName) %>&background=1c1c22&color=7a7774" class="w-6 h-6 rounded-full border-2 border-obsidian-200">
                <% }) %>
                <div class="w-6 h-6 rounded-full bg-zinc-800 border-2 border-obsidian-200 flex items-center justify-center text-[8px] font-black">+</div>
            </div>
        </div>
    </div>
</div>

<!-- Fund History Section -->
<div id="fund-history" class="glass-card p-8 md:p-10 mb-10 overflow-hidden">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-10 gap-6">
        <div>
            <h3 class="text-2xl font-black font-serif-heading text-white">Lịch sử thu chi quỹ phòng</h3>
            <p class="text-[10px] text-zinc-500 mt-2 uppercase tracking-[0.2em] font-black">Dữ liệu tài chính thời gian thực • 10 giao dịch gần nhất</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="px-4 py-2 bg-gold-500/5 rounded-xl border border-gold-500/10">
                <span class="text-[10px] font-black text-gold-500 uppercase tracking-widest">Minh bạch 100%</span>
            </div>
            <button class="w-10 h-10 bg-white/5 hover:bg-white/10 rounded-xl flex items-center justify-center text-zinc-400 transition-all">
                <i class="fa-solid fa-download"></i>
            </button>
        </div>
    </div>
    
    <div class="overflow-x-auto -mx-8 md:mx-0">
        <table class="w-full text-left min-w-[600px]">
            <thead>
                <tr class="text-[9px] font-black text-zinc-600 uppercase tracking-[0.2em] border-b border-white/5">
                    <th class="pb-6 px-8">Thời gian</th>
                    <th class="pb-6 px-8">Chi tiết giao dịch</th>
                    <th class="pb-6 px-8 text-right">Số tiền</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                <% if (fundHistory && fundHistory.length > 0) { %>
                    <% fundHistory.forEach(item => { %>
                        <tr class="group hover:bg-white/[0.02] transition-all">
                            <td class="py-6 px-8">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-obsidian-300 flex flex-col items-center justify-center border border-white/5">
                                        <span class="text-[10px] font-black text-white leading-none"><%= moment(item.date).format('DD') %></span>
                                        <span class="text-[8px] font-black text-gold-500 uppercase leading-none mt-1"><%= moment(item.date).format('MMM') %></span>
                                    </div>
                                    <div>
                                        <p class="text-[11px] font-black text-white uppercase tracking-tighter"><%= moment(item.date).format('dddd') %></p>
                                        <p class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest"><%= moment(item.date).format('HH:mm') %></p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-6 px-8">
                                <div class="flex flex-col gap-1">
                                    <p class="text-sm font-bold text-zinc-200"><%= item.description.split('|')[0] %></p>
                                    <div class="flex flex-wrap gap-2 mt-2">
                                        <% if (item.description.includes('|')) { %>
                                            <% item.description.split('|').slice(1).forEach(part => { %>
                                                <span class="text-[9px] font-black bg-obsidian-400 text-zinc-500 px-2 py-0.5 rounded border border-white/5 uppercase tracking-tighter">
                                                    <%= part.trim() %>
                                                </span>
                                            <% }) %>
                                        <% } %>
                                        <span class="text-[9px] font-black uppercase tracking-widest <%= item.type === 'income' ? 'text-emerald-500/70' : 'text-rose-500/70' %>">
                                            <i class="fa-solid <%= item.type === 'income' ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %> mr-1"></i>
                                            <%= item.type === 'income' ? 'Nguồn thu' : 'Chi phí' %>
                                        </span>
                                    </div>
                                </div>
                            </td>
                            <td class="py-6 px-8 text-right">
                                <span class="text-xl font-black font-serif-heading tracking-tight <%= item.type === 'income' ? 'text-emerald-500' : 'text-rose-500' %>">
                                    <%= item.type === 'income' ? '+' : '-' %><%= item.amount.toLocaleString('vi-VN') %><span class="text-xs font-sans ml-1 opacity-50 uppercase">đ</span>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="3" class="py-20 text-center">
                            <div class="flex flex-col items-center opacity-20">
                                <i class="fa-solid fa-receipt text-5xl mb-4"></i>
                                <p class="text-xs font-black uppercase tracking-widest">Chưa có giao dịch nào</p>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Fund Usage Section (Recently recorded) -->
<div class="glass-card p-10 mb-12 border-white/5">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-10 gap-6">
        <div>
            <h3 class="text-2xl font-black font-serif-heading text-white">Sử dụng quỹ gần đây</h3>
            <p class="text-[10px] text-zinc-500 mt-2 uppercase tracking-[0.2em] font-black">Các khoản chi trực tiếp từ quỹ phòng • Minh bạch & Rõ ràng</p>
        </div>
        <div class="w-14 h-14 bg-white/5 rounded-3xl flex items-center justify-center text-gold-500 shadow-2xl shadow-black/20 border border-white/5">
            <i class="fa-solid fa-file-invoice-dollar text-2xl"></i>
        </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% 
            const recentExpenses = fundHistory.filter(h => h.type === 'expense').slice(0, 6);
            if (recentExpenses.length > 0) { 
                recentExpenses.forEach(item => {
        %>
            <div class="p-6 bg-obsidian-300 border border-white/5 rounded-3xl group hover:border-gold-500/20 transition-all">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest"><%= moment(item.date).format('DD/MM/YYYY') %></span>
                    <i class="fa-solid fa-circle-minus text-rose-500/50 text-xs"></i>
                </div>
                <h4 class="text-sm font-bold text-white mb-3 line-clamp-2"><%= item.description.split('(')[0] %></h4>
                <div class="flex items-center justify-between pt-4 border-t border-white/5">
                    <p class="text-xl font-black font-serif-heading text-rose-500">-<%= item.amount.toLocaleString('vi-VN') %><span class="text-[10px] font-sans ml-1 opacity-50 uppercase">đ</span></p>
                    <span class="text-[8px] font-black text-zinc-600 uppercase tracking-tighter"><%= item.userId ? item.userId.fullName.split(' ').pop() : 'Admin' %></span>
                </div>
            </div>
        <% 
                });
            } else { 
        %>
            <div class="col-span-full py-12 text-center opacity-20">
                <p class="text-[10px] font-black uppercase tracking-widest">Chưa có dữ liệu chi quỹ gần đây</p>
            </div>
        <% } %>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-12">
    <!-- Member List -->
    <div class="glass-card p-10 border-white/5">
        <div class="flex items-center justify-between mb-10">
            <div>
                <h3 class="text-2xl font-black font-serif-heading text-white">Thành viên buồng</h3>
                <p class="text-[10px] text-zinc-500 mt-1 uppercase tracking-widest font-black">Nhân sự hiện tại trong buồng</p>
            </div>
            <span class="text-[10px] font-black text-gold-500 bg-gold-500/10 px-4 py-2 rounded-xl border border-gold-500/20 uppercase tracking-[0.2em]"><%= members.length %> NGƯỜI</span>
        </div>
        <div class="space-y-6">
            <% members.forEach(member => { %>
                <div class="flex items-center justify-between group p-4 hover:bg-white/[0.02] rounded-2xl transition-all border border-transparent hover:border-white/5">
                    <div class="flex items-center gap-5">
                        <div class="relative">
                            <% if (member.avatar) { %>
                                <img src="<%= member.avatar %>" class="w-14 h-14 rounded-2xl object-cover border-2 border-white/5 group-hover:border-gold-500/30 transition-all">
                            <% } else { %>
                                <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(member.fullName) %>&background=0D0D0F&color=C9A96E" class="w-14 h-14 rounded-2xl border-2 border-white/5 group-hover:border-gold-500/30 transition-all">
                            <% } %>
                            <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-2 border-obsidian-200 rounded-full"></div>
                        </div>
                        <div>
                            <h4 class="text-lg font-black text-white"><%= member.fullName %></h4>
                            <div class="flex items-center gap-3 mt-1">
                                <span class="text-[10px] text-zinc-500 font-black uppercase tracking-widest"><%= member.room %></span>
                                <span class="w-1 h-1 bg-zinc-800 rounded-full"></span>
                                <span class="text-[10px] text-gold-500 font-black uppercase tracking-widest"><%= member.role === 'super_admin' ? 'Chủ phòng' : 'Thành viên' %></span>
                            </div>
                        </div>
                    </div>
                    <button class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center text-zinc-500 hover:text-white transition-all">
                        <i class="fa-solid fa-ellipsis"></i>
                    </button>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Duty Schedule (Weekly) -->
    <div class="glass-card p-10 border-white/5">
        <div class="flex items-center justify-between mb-10">
            <div>
                <h3 class="text-2xl font-black font-serif-heading text-white">Lịch trực nhật tuần này</h3>
                <p class="text-[10px] text-zinc-500 mt-1 uppercase tracking-widest font-black">Phân công nhiệm vụ định kỳ</p>
            </div>
            <div class="w-12 h-12 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-400">
                <i class="fa-solid fa-calendar-week text-xl"></i>
            </div>
        </div>
        <div class="grid grid-cols-7 gap-3 mb-10">
            <% ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'].forEach((day, index) => { 
                const dayDate = moment().startOf('week').add(1 + index, 'day');
                const duty = weeklyDuties.find(d => moment(d.date).isSame(dayDate, 'day'));
                const isToday = moment().isSame(dayDate, 'day');
            %>
                <div class="text-center group">
                    <p class="text-[10px] font-black <%= isToday ? 'text-gold-500' : 'text-zinc-600' %> mb-3 uppercase tracking-tighter"><%= day %></p>
                    <div class="w-full aspect-square rounded-2xl flex flex-col items-center justify-center text-xs font-black border transition-all cursor-help relative shadow-lg
                        <%= isToday ? 'bg-gold-500/20 border-gold-500/40 text-gold-500 scale-110 z-10 shadow-gold-500/10' : (duty ? 'bg-obsidian-300 border-white/10 text-white' : 'bg-zinc-950/50 border-white/5 text-zinc-800') %>"
                        title="<%= duty ? duty.userId.fullName + ': ' + duty.task : 'Trống' %>">
                        <span class="text-xl filter <%= duty ? '' : 'grayscale opacity-30' %>"><%= duty ? (duty.task.includes('Nấu') ? '🍳' : '🧹') : '💤' %></span>
                        <% if (duty) { %>
                            <div class="absolute -top-1 -right-1 w-3 h-3 bg-gold-500 rounded-full border-2 border-obsidian-300"></div>
                        <% } %>
                    </div>
                    <p class="text-[8px] font-black text-zinc-600 mt-3 truncate"><%= duty ? duty.userId.fullName.split(' ').pop() : '' %></p>
                </div>
            <% }) %>
        </div>
        <div class="p-6 bg-gold-500/5 border border-gold-500/10 rounded-3xl flex items-center gap-6 group hover:border-gold-500/30 transition-all">
            <div class="w-14 h-14 bg-gold-500/10 rounded-2xl flex items-center justify-center text-gold-500 text-2xl group-hover:scale-110 transition-transform shadow-xl shadow-gold-500/5">
                <i class="fa-solid fa-bullhorn"></i>
            </div>
            <div>
                <p class="text-[10px] font-black text-gold-500 uppercase tracking-[0.2em] mb-1">Loa phóng thanh</p>
                <p class="text-[13px] text-zinc-300 font-medium leading-relaxed">
                    <% if (todayDuty) { %>
                        Hôm nay <strong class="text-white font-black"><%= todayDuty.userId.fullName %></strong> sẽ đảm nhiệm: <span class="text-gold-500 italic"><%= todayDuty.task %></span>. Hãy hỗ trợ nhau nhé!
                    <% } else { %>
                        Hôm nay cả buồng được nghỉ ngơi, không có lịch trực nhật.
                    <% } %>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Violation History Table -->
<div class="glass-card p-10 mb-12 border-rose-500/10">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-10 gap-6">
        <div>
            <h3 class="text-2xl font-black font-serif-heading text-white">Toàn bộ lịch sử vi phạm</h3>
            <p class="text-[10px] text-zinc-500 mt-2 uppercase tracking-[0.2em] font-black">Danh sách công khai mọi lỗi vi phạm trong buồng</p>
        </div>
        <div class="w-14 h-14 bg-rose-500/10 rounded-3xl flex items-center justify-center text-rose-500 shadow-2xl shadow-rose-500/5 border border-rose-500/20">
            <i class="fa-solid fa-gavel text-2xl"></i>
        </div>
    </div>
    <div class="overflow-x-auto -mx-10 md:mx-0">
        <table class="w-full text-left min-w-[700px]">
            <thead>
                <tr class="text-[9px] font-black text-zinc-600 uppercase tracking-[0.2em] border-b border-white/5">
                    <th class="pb-6 px-10">Người vi phạm</th>
                    <th class="pb-6 px-10">Nội dung & Người gán</th>
                    <th class="pb-6 px-10">Số tiền gốc</th>
                    <th class="pb-6 px-10 text-right">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                <% if (fines && fines.length > 0) { %>
                    <% fines.forEach(fine => { %>
                        <tr class="group hover:bg-white/[0.02] transition-all">
                            <td class="py-6 px-10">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-xl overflow-hidden border-2 border-white/5 group-hover:border-rose-500/30 transition-all">
                                        <% if (fine.userId.avatar) { %>
                                            <img src="<%= fine.userId.avatar %>" class="w-full h-full object-cover">
                                        <% } else { %>
                                            <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(fine.userId.fullName) %>&background=0D0D0F&color=f43f5e" class="w-full h-full">
                                        <% } %>
                                    </div>
                                    <div>
                                        <span class="text-sm font-black text-white block"><%= fine.userId.fullName %></span>
                                        <span class="text-[9px] text-zinc-500 font-black uppercase tracking-widest">Mã VP: #<%= fine._id.toString().slice(-6).toUpperCase() %></span>
                                    </div>
                                </div>
                            </td>
                            <td class="py-6 px-10">
                                <div class="flex flex-col gap-1">
                                    <p class="text-sm font-bold text-zinc-200"><%= fine.reason %></p>
                                    <p class="text-[10px] text-zinc-500 font-black uppercase tracking-widest flex items-center gap-2">
                                        <i class="fa-solid fa-user-pen text-[8px]"></i>
                                        Gán bởi: <span class="text-gold-500/80"><%= fine.createdBy ? fine.createdBy.fullName : 'Hệ thống' %></span>
                                    </p>
                                </div>
                            </td>
                            <td class="py-6 px-10">
                                <div class="flex flex-col">
                                    <span class="text-lg font-black font-serif-heading text-white"><%= fine.amount.toLocaleString('vi-VN') %>đ</span>
                                    <span class="text-[9px] text-zinc-600 font-black uppercase tracking-tighter">Gốc: <%= fine.originalAmount ? fine.originalAmount.toLocaleString('vi-VN') : fine.amount.toLocaleString('vi-VN') %>đ</span>
                                </div>
                            </td>
                            <td class="py-6 px-10 text-right">
                                <% if (fine.status === 'paid') { %>
                                    <span class="px-4 py-2 bg-emerald-500/10 text-emerald-500 text-[10px] font-black rounded-xl border border-emerald-500/20 uppercase tracking-widest">
                                        <i class="fa-solid fa-check-circle mr-1"></i> Đã nộp
                                    </span>
                                <% } else { %>
                                    <div class="flex flex-col items-end gap-1">
                                        <span class="px-4 py-2 bg-rose-500/10 text-rose-500 text-[10px] font-black rounded-xl border border-rose-500/20 uppercase tracking-widest">
                                            <i class="fa-solid fa-clock mr-1"></i> Chưa đóng
                                        </span>
                                        <span class="text-[8px] text-rose-400 font-black uppercase tracking-tighter animate-pulse">Đang tính lãi 2.5%</span>
                                    </div>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="py-20 text-center">
                            <div class="flex flex-col items-center opacity-20">
                                <i class="fa-solid fa-shield-heart text-5xl mb-4"></i>
                                <p class="text-xs font-black uppercase tracking-widest">Buồng chưa có ai vi phạm</p>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modals -->
<!-- Fine Modal -->
<div id="fineModal" class="fixed inset-0 bg-obsidian-500/90 backdrop-blur-xl hidden z-[300] flex items-center justify-center p-6 transition-all duration-500">
    <div class="glass-card w-full max-w-lg overflow-hidden border-gold-500/20 shadow-[0_0_100px_rgba(201,169,110,0.1)]">
        <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]">
            <div>
                <h3 class="text-3xl font-black font-serif-heading text-white">Ghi nhận vi phạm</h3>
                <p class="text-zinc-500 text-[10px] uppercase tracking-widest font-black mt-2">Truy cứu trách nhiệm thành viên</p>
            </div>
            <button onclick="document.getElementById('fineModal').classList.add('hidden')" class="w-12 h-12 rounded-2xl bg-white/5 hover:bg-rose-500/20 hover:text-rose-500 flex items-center justify-center transition-all text-zinc-400">
                <i class="fa-solid fa-times text-xl"></i>
            </button>
        </div>
        <form action="/room/fine/create" method="POST" class="p-8 space-y-8">
            <div class="space-y-4">
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Người vi phạm</label>
                <div class="relative group">
                    <select name="userId" required class="w-full bg-obsidian-300 border border-white/5 rounded-2xl px-6 py-5 text-white font-bold focus:outline-none focus:border-gold-500/50 appearance-none transition-all">
                        <% allUsers.forEach(u => { %>
                            <option value="<%= u._id %>"><%= u.fullName %></option>
                        <% }) %>
                    </select>
                    <i class="fa-solid fa-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-zinc-600 pointer-events-none group-focus-within:rotate-180 transition-transform"></i>
                </div>
            </div>
            <div class="space-y-4">
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Nội dung vi phạm</label>
                <input type="text" name="reason" placeholder="Ví dụ: Đi muộn, Không trực nhật..." required
                    class="w-full bg-obsidian-300 border border-white/5 rounded-2xl px-6 py-5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
            </div>
            <div class="space-y-4">
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Số tiền phạt (đ)</label>
                <div class="relative">
                    <input type="number" name="amount" placeholder="50000" required
                        class="w-full bg-obsidian-300 border border-white/5 rounded-2xl px-6 py-5 text-white font-black text-3xl focus:outline-none focus:border-rose-500/50 transition-all placeholder:text-zinc-800">
                    <span class="absolute right-6 top-1/2 -translate-y-1/2 text-zinc-600 font-black">VNĐ</span>
                </div>
            </div>
            <div class="p-5 bg-rose-500/5 border border-rose-500/10 rounded-3xl">
                <p class="text-[11px] text-rose-400 font-bold leading-relaxed flex gap-3">
                    <i class="fa-solid fa-circle-exclamation text-lg"></i>
                    <span>Chế tài: Tiền phạt sẽ tự động áp dụng lãi suất kép <strong class="text-rose-500">2.5% mỗi ngày</strong> nếu không nộp trong vòng 24h.</span>
                </p>
            </div>
            <button type="submit" class="w-full py-6 btn-primary-glow text-obsidian-500 font-black rounded-2xl uppercase tracking-[0.2em] text-sm shadow-2xl">
                XÁC NHẬN TRUY CỨU
            </button>
        </form>
    </div>
</div>

<!-- Unpaid Fines Modal -->
<div id="unpaidFinesModal" class="fixed inset-0 bg-obsidian-500/90 backdrop-blur-xl hidden z-[300] flex items-center justify-center p-6 transition-all duration-500">
    <div class="glass-card w-full max-w-2xl overflow-hidden border-rose-500/20 shadow-[0_0_100px_rgba(244,63,94,0.1)]">
        <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]">
            <div>
                <h3 class="text-3xl font-black font-serif-heading text-white">Danh sách nợ phạt</h3>
                <p class="text-rose-500 text-[10px] uppercase tracking-widest font-black mt-2">Cảnh báo thanh toán trễ hạn</p>
            </div>
            <button onclick="document.getElementById('unpaidFinesModal').classList.add('hidden')" class="w-12 h-12 rounded-2xl bg-white/5 hover:bg-white/10 flex items-center justify-center transition-all text-zinc-400">
                <i class="fa-solid fa-times text-xl"></i>
            </button>
        </div>
        <div class="p-8 max-h-[60vh] overflow-y-auto space-y-6 custom-scrollbar">
            <% 
                const unpaidList = fines.filter(f => f.status === 'unpaid');
                if (unpaidList.length > 0) {
                    unpaidList.forEach(fine => { 
            %>
                <div class="flex flex-col md:flex-row items-start md:items-center justify-between p-6 bg-obsidian-300 border border-white/5 rounded-3xl group hover:border-rose-500/30 transition-all gap-6">
                    <div class="flex items-center gap-5">
                        <div class="w-14 h-14 bg-rose-500/10 rounded-2xl flex items-center justify-center text-rose-500 text-2xl border border-rose-500/20">
                            <i class="fa-solid fa-user-ninja"></i>
                        </div>
                        <div>
                            <h5 class="text-lg font-black text-white"><%= fine.userId.fullName %></h5>
                            <p class="text-xs text-zinc-500 font-medium italic"><%= fine.reason %></p>
                            <p class="text-[9px] text-zinc-600 font-black uppercase mt-2 tracking-widest">Gán bởi: <%= fine.createdBy ? fine.createdBy.fullName : 'Hệ thống' %></p>
                        </div>
                    </div>
                    <div class="text-left md:text-right w-full md:w-auto">
                        <p class="text-2xl font-black text-rose-500 font-serif-heading"><%= fine.amount.toLocaleString('vi-VN') %><span class="text-xs font-sans ml-1 opacity-50">đ</span></p>
                        <p class="text-[9px] text-rose-400 uppercase tracking-[0.2em] font-black mt-1">Nợ quá hạn</p>
                    </div>
                </div>
            <% 
                    });
                } else { 
            %>
                <div class="text-center py-20">
                    <div class="w-20 h-20 bg-emerald-500/10 rounded-full flex items-center justify-center text-emerald-500 text-4xl mx-auto mb-6">
                        <i class="fa-solid fa-check-double"></i>
                    </div>
                    <p class="text-xs font-black text-zinc-500 uppercase tracking-widest">Không có vi phạm nào chưa đóng</p>
                </div>
            <% } %>
        </div>
        <div class="p-8 border-t border-white/5 bg-white/[0.01] text-center">
            <p class="text-[10px] text-zinc-600 font-black uppercase tracking-widest">Mọi dữ liệu được tự động cập nhật bởi hệ thống Pencake</p>
        </div>
    </div>
</div>

<!-- Fund Usage Modal -->
<div id="fundUsageModal" class="fixed inset-0 bg-obsidian-500/90 backdrop-blur-xl hidden z-[300] flex items-center justify-center p-6 transition-all duration-500">
    <div class="glass-card w-full max-w-lg overflow-hidden border-gold-500/20 shadow-[0_0_100px_rgba(201,169,110,0.1)]">
        <div class="p-8 border-b border-white/5 flex justify-between items-center bg-white/[0.02]">
            <div>
                <h3 class="text-3xl font-black font-serif-heading text-white">Sử dụng quỹ phòng</h3>
                <p class="text-zinc-500 text-[10px] uppercase tracking-widest font-black mt-2">Ghi nhận các khoản chi trực tiếp từ quỹ</p>
            </div>
            <button onclick="document.getElementById('fundUsageModal').classList.add('hidden')" class="w-12 h-12 rounded-2xl bg-white/5 hover:bg-rose-500/20 hover:text-rose-500 flex items-center justify-center transition-all text-zinc-400">
                <i class="fa-solid fa-times text-xl"></i>
            </button>
        </div>
        <form action="/room/fund/expense/create" method="POST" class="p-8 space-y-8">
            <div class="space-y-4">
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Lý do chi quỹ</label>
                <input type="text" name="description" placeholder="Ví dụ: Đóng tiền điện tháng 5, Mua bóng đèn hành lang..." required
                    class="w-full bg-obsidian-300 border border-white/5 rounded-2xl px-6 py-5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
            </div>
            <div class="space-y-4">
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em]">Số tiền chi (đ)</label>
                <div class="relative">
                    <input type="number" name="amount" placeholder="500000" required
                        class="w-full bg-obsidian-300 border border-white/5 rounded-2xl px-6 py-5 text-white font-black text-3xl focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-800">
                    <span class="absolute right-6 top-1/2 -translate-y-1/2 text-zinc-600 font-black">VNĐ</span>
                </div>
            </div>
            <div class="p-5 bg-gold-500/5 border border-gold-500/10 rounded-3xl">
                <p class="text-[11px] text-gold-500 font-bold leading-relaxed flex gap-3 italic">
                    <i class="fa-solid fa-circle-info text-lg"></i>
                    <span>Số tiền này sẽ được trừ trực tiếp vào số dư quỹ phòng hiện tại sau khi xác nhận.</span>
                </p>
            </div>
            <button type="submit" class="w-full py-6 btn-primary-glow text-obsidian-500 font-black rounded-2xl uppercase tracking-[0.2em] text-sm shadow-2xl">
                XÁC NHẬN CHI QUỸ
            </button>
        </form>
    </div>
</div>
</body>
</html>
