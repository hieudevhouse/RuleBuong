<div class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
    <div>
        <h2 class="text-5xl font-black tracking-tight font-serif-heading text-gradient-gold">Lịch làm việc</h2>
        <p class="text-zinc-400 mt-2 font-medium flex items-center gap-3">
            <span class="w-8 h-px bg-gold-500/30"></span>
            Quản lý <span class="text-gold-400">thời gian và hiệu suất</span> cá nhân.
        </p>
    </div>
    <div class="flex items-center gap-4 w-full md:w-auto">
        <div class="relative flex-1 md:flex-none">
            <i class="fa-solid fa-calendar-day absolute left-4 top-1/2 -translate-y-1/2 text-gold-500/50"></i>
            <input type="date" id="dateSelector" value="<%= selectedDate %>" 
                class="w-full bg-white/5 border border-white/10 rounded-2xl pl-12 pr-6 py-3.5 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all cursor-pointer shadow-xl backdrop-blur-md"
                onchange="window.location.href='/personal/schedule?date=' + this.value">
        </div>
        <button onclick="document.getElementById('taskModal').classList.remove('hidden')" 
            class="btn-primary-glow px-8 py-3.5 rounded-2xl whitespace-nowrap">
            <i class="fa-solid fa-plus mr-2"></i> Thêm lịch
        </button>
    </div>
</div>

<div class="glass-card overflow-hidden border-white/5">
    <!-- Header with Days -->
    <div class="bg-white/[0.02] border-b border-white/5 p-8 flex items-center justify-between backdrop-blur-2xl">
        <div class="flex items-center gap-8">
            <div class="relative">
                <div class="w-20 h-20 bg-gold-500 rounded-3xl flex items-center justify-center text-obsidian-500 text-4xl font-black shadow-[0_0_40px_rgba(201,169,110,0.3)]">
                    <%= moment(selectedDate).format('DD') %>
                </div>
                <div class="absolute -top-2 -right-2 w-6 h-6 bg-white rounded-full flex items-center justify-center text-[10px] font-black text-obsidian-500 border-2 border-obsidian-500">
                    !
                </div>
            </div>
            <div>
                <h3 class="text-4xl font-black font-serif-heading text-white">
                    Thứ <%= moment(selectedDate).format('E') === '1' ? 'Hai' : (moment(selectedDate).format('E') === '7' ? 'Chủ Nhật' : (parseInt(moment(selectedDate).format('E')) + 1)) %>
                </h3>
                <div class="flex items-center gap-2 mt-1">
                    <p class="text-xs text-gold-500/60 font-black uppercase tracking-[0.2em]">Tháng <%= moment(selectedDate).format('MM, YYYY') %></p>
                </div>
            </div>
        </div>
        <div class="flex gap-4">
            <button onclick="navigateDate(-1)" class="w-14 h-14 flex items-center justify-center bg-white/5 hover:bg-white/10 rounded-2xl text-white transition-all border border-white/5 group">
                <i class="fa-solid fa-chevron-left group-hover:-translate-x-1 transition-transform"></i>
            </button>
            <button onclick="navigateDate(1)" class="w-14 h-14 flex items-center justify-center bg-white/5 hover:bg-white/10 rounded-2xl text-white transition-all border border-white/5 group">
                <i class="fa-solid fa-chevron-right group-hover:translate-x-1 transition-transform"></i>
            </button>
        </div>
    </div>

    <!-- Time Grid -->
    <div class="h-[650px] overflow-y-auto custom-scrollbar">
        <div class="relative min-h-[1440px]">
            <% for(let h=0; h<24; h++) { %>
                <div class="flex border-b border-white/[0.05] group h-[60px]">
                    <div class="w-24 py-3 pr-6 text-right text-xs font-black text-zinc-500 uppercase tracking-widest border-r border-white/10 bg-zinc-900/40">
                        <%= h < 10 ? '0'+h : h %>:00
                    </div>
                    <div class="flex-1 relative group-hover:bg-white/[0.03] transition-colors cursor-pointer" 
                        onclick="openAddTaskAt('<%= h < 10 ? '0'+h : h %>:00')">
                        <% tasks.forEach(task => { 
                            const startH = moment(task.startTime).hour();
                            const startM = moment(task.startTime).minute();
                            const durationMin = moment.duration(moment(task.endTime).diff(moment(task.startTime))).asMinutes();
                            
                            if(startH === h) { %>
                                <div class="absolute left-4 right-8 z-10 p-5 <%= task.status === 'completed' ? 'bg-zinc-800/40 border-zinc-600/30 opacity-50' : 'bg-gold-500/10 border-gold-500/40 shadow-[0_20px_50px_rgba(0,0,0,0.3)]' %> border-l-[4px] rounded-2xl backdrop-blur-xl group/task transition-all hover:scale-[1.02] hover:z-20"
                                     style="top: <%= (startM / 60) * 100 %>%; height: <%= (durationMin / 60) * 60 %>px;"
                                     onclick="event.stopPropagation()">
                                    <div class="flex justify-between items-center h-full">
                                        <div>
                                            <h4 class="text-base font-black <%= task.status === 'completed' ? 'text-zinc-500 line-through' : 'text-white' %> truncate max-w-[200px] mb-1"><%= task.title %></h4>
                                            <div class="flex items-center gap-3">
                                                <span class="text-[10px] <%= task.status === 'completed' ? 'text-zinc-600' : 'text-gold-500' %> font-black uppercase tracking-widest flex items-center gap-1.5">
                                                    <i class="fa-regular fa-clock"></i>
                                                    <%= moment(task.startTime).format('HH:mm') %> - <%= moment(task.endTime).format('HH:mm') %>
                                                </span>
                                                <% if(task.status !== 'completed') { %>
                                                    <span class="w-1 h-1 rounded-full bg-gold-500/30"></span>
                                                    <span class="text-[9px] text-white/40 font-black uppercase tracking-tighter">In Progress</span>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="flex gap-3 opacity-0 group-hover/task:opacity-100 transition-all transform translate-x-2 group-hover/task:translate-x-0">
                                            <form action="/personal/schedule/toggle/<%= task._id %>?date=<%= selectedDate %>" method="POST" class="inline">
                                                <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/10 hover:bg-emerald-500 hover:text-zinc-950 text-emerald-400 transition-all shadow-lg" title="Hoàn thành">
                                                    <i class="fa-solid <%= task.status === 'completed' ? 'fa-circle-check' : 'fa-circle' %> text-sm"></i>
                                                </button>
                                            </form>
                                            <button data-task='<%= JSON.stringify(task).replace(/'/g, "&#39;") %>'
                                                onclick="openEditTask(this)" 
                                                class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/10 hover:bg-amber-500 hover:text-zinc-950 text-amber-400 transition-all shadow-lg" title="Sửa">
                                                <i class="fa-solid fa-pen-to-square text-sm"></i>
                                            </button>
                                            <form action="/personal/schedule/delete/<%= task._id %>?date=<%= selectedDate %>" method="POST" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?')">
                                                <button type="submit" class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/10 hover:bg-rose-500 hover:text-white text-rose-400 transition-all shadow-lg" title="Xóa">
                                                    <i class="fa-solid fa-trash text-sm"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% } 
                        }) %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Task Modal -->
<div id="taskModal" class="fixed inset-0 bg-obsidian-500/90 backdrop-blur-xl z-[500] flex items-center justify-center hidden p-6">
    <div class="glass-card p-10 w-full max-w-lg border-gold-500/20 shadow-[0_0_100px_rgba(201,169,110,0.1)]">
        <div class="flex justify-between items-center mb-10">
            <div>
                <h3 id="modalTitle" class="text-3xl font-black font-serif-heading text-white">Thêm lịch mới</h3>
                <p class="text-[10px] text-gold-500/50 uppercase tracking-[0.2em] font-black mt-1">Lập kế hoạch cho ngày của bạn</p>
            </div>
            <button onclick="document.getElementById('taskModal').classList.add('hidden')" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 text-zinc-500 hover:text-white hover:bg-white/10 transition-all">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        
        <form id="taskForm" action="/personal/schedule/create" method="POST" class="space-y-8">
            <input type="hidden" name="date" value="<%= selectedDate %>">
            <div>
                <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em] mb-3">Tên công việc</label>
                <input type="text" name="title" id="modalTitleInput" required placeholder="Ví dụ: Họp team, Tập gym..."
                    class="w-full bg-white/[0.03] border border-white/10 rounded-2xl px-6 py-4 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all placeholder:text-zinc-700">
            </div>
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em] mb-3">Giờ bắt đầu</label>
                    <input type="time" name="startTime" id="modalStartTime" required
                        class="w-full bg-white/[0.03] border border-white/10 rounded-2xl px-6 py-4 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em] mb-3">Thời lượng</label>
                    <div class="relative">
                        <select name="duration" id="modalDuration" class="w-full bg-white/[0.03] border border-white/10 rounded-2xl px-6 py-4 text-white font-bold focus:outline-none focus:border-gold-500/50 transition-all appearance-none">
                            <option value="1">01 Giờ</option>
                            <option value="2">02 Giờ</option>
                            <option value="3">03 Giờ</option>
                            <option value="4">04 Giờ</option>
                        </select>
                        <i class="fa-solid fa-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-zinc-600 pointer-events-none"></i>
                    </div>
                </div>
            </div>
            <button type="submit" id="modalSubmitBtn" class="btn-primary-glow w-full py-5 rounded-2xl text-base">
                Lưu lịch làm việc
            </button>
        </form>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(201, 169, 110, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(201, 169, 110, 0.2); }
</style>

<script>
    function navigateDate(days) {
        const current = new Date('<%= selectedDate %>');
        current.setDate(current.getDate() + days);
        const yyyy = current.getFullYear();
        const mm = String(current.getMonth() + 1).padStart(2, '0');
        const dd = String(current.getDate()).padStart(2, '0');
        window.location.href = `/personal/schedule?date=${yyyy}-${mm}-${dd}`;
    }

    function openAddTaskAt(time) {
        document.getElementById('modalTitle').innerText = 'Thêm lịch mới';
        document.getElementById('taskForm').action = '/personal/schedule/create';
        document.getElementById('modalTitleInput').value = '';
        document.getElementById('modalStartTime').value = time;
        document.getElementById('modalDuration').value = '1';
        document.getElementById('modalSubmitBtn').innerText = 'Lưu lịch làm việc';
        document.getElementById('taskModal').classList.remove('hidden');
    }

    function openEditTask(el) {
        const task = JSON.parse(el.dataset.task);
        const startTime = new Date(task.startTime);
        const endTime = new Date(task.endTime);
        const duration = Math.round((endTime - startTime) / (1000 * 60 * 60));

        document.getElementById('modalTitle').innerText = 'Chỉnh sửa lịch';
        document.getElementById('taskForm').action = '/personal/schedule/update/' + task._id;
        document.getElementById('modalTitleInput').value = task.title;
        document.getElementById('modalStartTime').value = startTime.getHours().toString().padStart(2, '0') + ':' + startTime.getMinutes().toString().padStart(2, '0');
        document.getElementById('modalDuration').value = duration.toString();
        document.getElementById('modalSubmitBtn').innerText = 'Cập nhật lịch';
        document.getElementById('taskModal').classList.remove('hidden');
    }
</script>