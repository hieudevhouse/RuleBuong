<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gold: {
                            400: '#E8D5A3',
                            500: '#C9A96E',
                            600: '#B8965A',
                        },
                        obsidian: {
                            400: '#1C1C22',
                            500: '#0D0D0F',
                            600: '#050505',
                        }
                    },
                    fontFamily: {
                        sans: ['DM Sans', 'sans-serif'],
                        serif: ['Instrument Serif', 'serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #050505;
            color: #F0EDE8;
            overflow-x: hidden;
        }

        .text-gradient-gold {
            background: linear-gradient(135deg, #FDFBF7 0%, #C9A96E 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .auth-glass-panel {
            background: rgba(13, 13, 15, 0.7);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(201, 169, 110, 0.1);
            box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.8);
        }

        .bg-mesh {
            position: fixed;
            inset: 0;
            z-index: -1;
            background: 
                radial-gradient(circle at 0% 0%, rgba(201, 169, 110, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(201, 169, 110, 0.05) 0%, transparent 50%);
        }

        .btn-primary-glow {
            background: linear-gradient(135deg, #FDFBF7 0%, #C9A96E 50%, #B8965A 100%);
            box-shadow: 0 15px 30px rgba(201, 169, 110, 0.2);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-primary-glow:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 40px rgba(201, 169, 110, 0.35);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-6 relative">
    
    <div class="bg-mesh"></div>
    
    <!-- Animated Orbs -->
    <div class="fixed top-[-10%] left-[-10%] w-[40%] h-[40%] bg-gold-500/5 blur-[120px] rounded-full animate-pulse"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-gold-500/5 blur-[120px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>

    <div class="w-full max-w-6xl mx-auto z-10 flex min-h-[700px] rounded-[2.5rem] overflow-hidden auth-glass-panel">
        <%- body %>
    </div>

</body>
</html>
