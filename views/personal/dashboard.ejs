<%#============================================================Pencake — Dashboard Cá nhân (partial EJS) Tối ưu
    responsive + typography + highlight============================================================%>

    <style>
        /* ── Typography & Tokens ── */
        .db-heading {
            font-family: 'Instrument Serif', Georgia, serif;
            letter-spacing: -0.02em;
            line-height: 1.1;
        }

        .text-gradient-gold {
            background: linear-gradient(135deg, #FDFBF7 0%, #C9A96E 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* ── Page Header ── */
        .db-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 2rem;
            margin-bottom: 3rem;
            flex-wrap: wrap;
        }

        .db-header-left h2 {
            font-size: clamp(2.5rem, 5vw, 3.5rem);
            font-weight: 900;
        }

        .db-header-left p {
            font-size: .9rem;
            color: #7A7774;
            margin-top: .5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .db-header-left p::before {
            content: '';
            width: 30px;
            height: 1px;
            background: rgba(201, 169, 110, 0.3);
        }

        .db-username {
            color: #C9A96E;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .db-header-actions {
            display: flex;
            gap: 1rem;
            flex-shrink: 0;
        }

        .db-btn-ghost {
            display: inline-flex;
            align-items: center;
            gap: .75rem;
            padding: .85rem 1.75rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 16px;
            font-size: .85rem;
            font-weight: 800;
            color: #F0EDE8;
            cursor: pointer;
            transition: all .3s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .db-btn-ghost:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(255, 255, 255, 0.12);
            transform: translateY(-2px);
        }

        .db-btn-gold {
            display: inline-flex;
            align-items: center;
            gap: .75rem;
            padding: .85rem 1.75rem;
            background: linear-gradient(135deg, #F4EAD5 0%, #C9A96E 50%, #B8965A 100%);
            border: none;
            border-radius: 16px;
            font-size: .85rem;
            font-weight: 900;
            color: #09090B;
            cursor: pointer;
            transition: all .3s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            box-shadow: 0 12px 24px rgba(201, 169, 110, 0.2);
        }

        .db-btn-gold:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 32px rgba(201, 169, 110, 0.35);
        }

        /* ── Summary Cards ── */
        .db-cards {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .db-card {
            position: relative;
            padding: 2rem;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(255, 255, 255, 0.02);
            text-decoration: none;
            display: block;
            overflow: hidden;
            transition: all .4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .db-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(201, 169, 110, 0.2);
            box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4);
        }

        .db-card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.75rem;
        }

        .db-card-icon {
            width: 54px;
            height: 54px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all .4s ease;
        }

        .db-card:hover .db-card-icon {
            transform: scale(1.1) rotate(-5deg);
            background: var(--card-accent-soft);
            color: var(--card-accent);
            border-color: var(--card-accent-border);
        }

        .db-card-badge {
            font-size: .6rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .15em;
            padding: .4rem .8rem;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.03);
            color: #7A7774;
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .db-card:hover .db-card-badge {
            background: var(--card-accent-soft);
            color: var(--card-accent);
            border-color: var(--card-accent-border);
        }

        .db-card-value {
            font-family: 'Instrument Serif', Georgia, serif;
            font-size: clamp(2.2rem, 3.5vw, 3.2rem);
            font-weight: 800;
            color: #F0EDE8;
            letter-spacing: -0.04em;
            line-height: 1;
            margin-bottom: .75rem;
            transition: color .3s ease;
        }

        .db-card:hover .db-card-value {
            color: #FFF;
        }

        .db-card-value .unit {
            font-family: 'DM Sans', sans-serif;
            font-size: .9rem;
            font-weight: 500;
            color: #4A4845;
            letter-spacing: 0;
            margin-left: 0.25rem;
        }

        .db-card-label {
            font-size: .7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .15em;
            color: #4A4845;
            transition: color .3s ease;
        }

        .db-card:hover .db-card-label {
            color: #7A7774;
        }

        /* ── Notes Section ── */
        .db-notes-card {
            border-radius: 32px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(255, 255, 255, 0.01);
            overflow: hidden;
            box-shadow: 0 32px 64px rgba(0, 0, 0, 0.2);
        }

        .db-notes-header {
            padding: 2.5rem 3rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(255, 255, 255, 0.02);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 2rem;
        }

        .db-notes-header-text h3 {
            font-size: 2rem;
            font-weight: 900;
            color: #F0EDE8;
        }

        .db-notes-header-text p {
            font-size: .9rem;
            color: #7A7774;
            margin-top: .5rem;
            font-weight: 500;
        }

        .db-notes-header-icon {
            width: 64px;
            height: 64px;
            background: rgba(201, 169, 110, 0.05);
            border: 1px solid rgba(201, 169, 110, 0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #C9A96E;
            font-size: 1.8rem;
            flex-shrink: 0;
            box-shadow: 0 10px 20px rgba(201, 169, 110, 0.05);
        }

        .db-notes-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .db-notes-form-col {
            padding: 3rem;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .db-notes-history-col {
            padding: 3rem;
            background: rgba(0, 0, 0, 0.1);
        }

        .db-textarea {
            width: 100%;
            background: rgba(13, 13, 15, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 24px;
            padding: 1.5rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem;
            line-height: 1.8;
            color: #F0EDE8;
            resize: none;
            outline: none;
            transition: all .3s ease;
            margin-bottom: 1.5rem;
        }

        .db-textarea:focus {
            border-color: rgba(201, 169, 110, 0.3);
            background: rgba(13, 13, 15, 0.8);
            box-shadow: 0 0 0 4px rgba(201, 169, 110, 0.05);
        }

        .db-submit-btn {
            width: 100%;
            padding: 1.25rem;
            border-radius: 20px;
            border: none;
            cursor: pointer;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .15em;
            color: #09090B;
            background: linear-gradient(135deg, #F4EAD5 0%, #C9A96E 50%, #B8965A 100%);
            box-shadow: 0 16px 32px rgba(201, 169, 110, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
            transition: all .3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: .85rem;
        }

        .db-submit-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(201, 169, 110, 0.3);
        }

        .db-notes-history-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .db-notes-history-label span:first-child {
            font-size: .75rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .2em;
            color: #4A4845;
        }

        .db-badge-new {
            font-size: .65rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: #C9A96E;
            background: rgba(201, 169, 110, 0.08);
            padding: .4rem .8rem;
            border-radius: 10px;
            border: 1px solid rgba(201, 169, 110, 0.15);
        }

        .db-notes-list {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            max-height: 450px;
            overflow-y: auto;
            padding-right: 1.5rem;
        }

        .db-note-item {
            position: relative;
            padding-left: 2rem;
            border-left: 1px solid rgba(201, 169, 110, 0.2);
            padding-bottom: 0.5rem;
        }

        .db-note-dot {
            position: absolute;
            width: 10px;
            height: 10px;
            background: #C9A96E;
            border-radius: 50%;
            left: -5.5px;
            top: 4px;
            box-shadow: 0 0 15px rgba(201, 169, 110, 0.4);
        }

        .db-note-time {
            font-size: .7rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: rgba(201, 169, 110, 0.6);
            margin-bottom: .6rem;
            display: block;
        }

        .db-note-text {
            font-size: 1.05rem;
            color: #E2E0DD;
            line-height: 1.8;
            font-weight: 400;
        }

        /* ── Responsive ── */
        @media (max-width: 1400px) {
            .db-cards {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 1024px) {
            .db-notes-body {
                grid-template-columns: 1fr;
            }

            .db-notes-form-col {
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            }

            .db-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .db-header-actions {
                width: 100%;
            }

            .db-btn-ghost,
            .db-btn-gold {
                flex: 1;
                justify-content: center;
            }
        }

        @media (max-width: 640px) {
            .db-cards {
                grid-template-columns: 1fr;
            }

            .db-notes-header,
            .db-notes-form-col,
            .db-notes-history-col {
                padding: 2rem;
            }

            .db-header-left h2 {
                font-size: 2.2rem;
            }
        }
    </style>

    <!-- ═══════════════════════════════════════
     PAGE HEADER
═══════════════════════════════════════ -->
    <div class="db-header">
        <div class="db-header-left">
            <h2 class="db-heading text-gradient-gold">Bảng điều khiển cá nhân</h2>
            <p>Xin chào, <span class="db-username">
                    <%= user.fullName %>
                </span>. Hôm nay bạn thế nào?</p>
        </div>
    </div>

    <!-- ═══════════════════════════════════════
     SUMMARY CARDS
═══════════════════════════════════════ -->
    <div class="db-cards">
        <!-- Việc cần làm -->
        <a href="/personal/schedule" class="db-card"
            style="--card-accent: #10b981; --card-accent-soft: rgba(16, 185, 129, 0.08); --card-accent-border: rgba(16, 185, 129, 0.2);">
            <div class="db-card-top">
                <div class="db-card-icon" style="color: #10b981; background: rgba(16, 185, 129, 0.05);">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <span class="db-card-badge">Hôm nay</span>
            </div>
            <div class="db-card-value">
                <%= stats.todayTasks %>
            </div>
            <div class="db-card-label">Việc cần làm</div>
        </a>

        <!-- Thu -->
        <a href="/personal/expenses?type=receivable" class="db-card"
            style="--card-accent: #3B82F6; --card-accent-soft: rgba(59, 130, 246, 0.08); --card-accent-border: rgba(59, 130, 246, 0.2);">
            <div class="db-card-top">
                <div class="db-card-icon" style="color: #3B82F6; background: rgba(59, 130, 246, 0.05);">
                    <i class="fa-solid fa-comments-dollar"></i>
                </div>
                <span class="db-card-badge">Cần thu</span>
            </div>
            <div class="db-card-value">
                <%= stats.receivable.toLocaleString('vi-VN') %><span class="unit">đ</span>
            </div>
            <div class="db-card-label">Người khác nợ bạn</div>
        </a>
    </div>

    <!-- ═══════════════════════════════════════
     NOTES SECTION
═══════════════════════════════════════ -->
    <div class="db-notes-card">

        <div class="db-notes-header">
            <div class="db-notes-header-text">
                <h3 class="db-heading">Nhật ký & Ghi chú</h3>
                <p>Lưu lại những ý tưởng và suy nghĩ quan trọng trong ngày</p>
            </div>
            <div class="db-notes-header-icon">
                <i class="fa-solid fa-feather-pointed"></i>
            </div>
        </div>

        <div class="db-notes-body">

            <!-- Form -->
            <div class="db-notes-form-col">
                <form id="noteForm" action="/personal/note/create" method="POST">
                    <textarea class="db-textarea" name="content" id="noteContent" rows="7" placeholder="Hôm nay bạn thế nào? Cần ghi nhớ điều gì không..."></textarea>
                    <button class="db-submit-btn" type="submit" id="noteSubmitBtn">
                        <span class="btn-text"><i class="fa-solid fa-pen-nib"></i> Lưu nhật ký</span>
                        <div class="db-spinner" id="noteSpinner"></div>
                    </button>
                </form>
            </div>

            <!-- History -->
            <div class="db-notes-history-col">
                <div class="db-notes-history-label">
                    <span>Lịch sử ghi chú</span>
                    <span class="db-badge-new">Mới nhất</span>
                </div>

                <div class="db-notes-list" id="notesList">
                    <% if (typeof notes !=='undefined' && notes.length> 0) { %>
                        <% notes.forEach(note=> { %>
                            <div class="db-note-item">
                                <div class="db-note-dot"></div>
                                <span class="db-note-time">
                                    <%= moment(note.createdAt).format('DD/MM/YYYY · HH:mm') %>
                                </span>
                                <p class="db-note-text">
                                    <%= note.content %>
                                </p>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="db-notes-empty" id="noNotes">
                                        <i class="fa-solid fa-feather"></i>
                                        <p>Chưa có nhật ký nào.</p>
                                    </div>
                                    <% } %>
                </div>
            </div>

        </div>
    </div>

    <!-- ═══════════════════════════════════════
     SCRIPT
═══════════════════════════════════════ -->
    <script>
        (function () {
            const form = document.getElementById('noteForm');
            const textarea = document.getElementById('noteContent');
            const btn = document.getElementById('noteSubmitBtn');
            const spinner = document.getElementById('noteSpinner');
            const btnText = btn.querySelector('.btn-text');
            const list = document.getElementById('notesList');

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const content = textarea.value.trim();
                if (!content) return;

                btn.disabled = true;
                btnText.style.opacity = '0';
                spinner.style.display = 'block';

                try {
                    const res = await fetch(form.action, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: JSON.stringify({ content })
                    });
                    const data = await res.json();

                    if (data.success) {
                        const noNotes = document.getElementById('noNotes');
                        if (noNotes) noNotes.remove();

                        const el = document.createElement('div');
                        el.className = 'db-note-item';
                        el.style.opacity = '0';
                        el.style.transform = 'translateY(-8px)';
                        el.style.transition = 'all .35s ease';
                        el.innerHTML = `
          <div class="db-note-dot"></div>
          <span class="db-note-time">Vừa xong</span>
          <p class="db-note-text">${data.note.content}</p>
        `;
                        list.insertBefore(el, list.firstChild);
                        requestAnimationFrame(() => {
                            requestAnimationFrame(() => {
                                el.style.opacity = '1';
                                el.style.transform = 'translateY(0)';
                            });
                        });
                        textarea.value = '';
                    }
                } catch (err) {
                    console.error('Note save error:', err);
                } finally {
                    btn.disabled = false;
                    btnText.style.opacity = '1';
                    spinner.style.display = 'none';
                }
            });
        })();
    </script>